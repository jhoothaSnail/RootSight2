# ─── RootSight environment ───────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values. `.env` is gitignored.

# Google Gemini API key — required for document extraction, root-cause
# reasoning, and runbook generation. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Neo4j (Aura) connection — required to persist and query the dependency graph.
# Create a free instance at https://neo4j.com/cloud/aura/
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Optional: URL where the app is hosted (self-referential links).
APP_URL="http://localhost:3000"

# ─── Frontend (Vite) — optional ──────────────────────────────────────────────
# Force the UI into fully-offline "demo mode" (always use local mocks, never
# call the backend). Set to "true" for a guaranteed-stable demo with no backend.
# VITE_USE_MOCKS=true

# Override the API origin (default: "" → dev proxy forwards /api to :3001).
# VITE_API_BASE_URL=
